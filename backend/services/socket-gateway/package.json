    "@cravix/shared-redis": "workspace:*",
    "@cravix/shared-types": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.7.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
