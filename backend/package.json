{
  "name": "cravix-backend",
  "private": true,
  "version": "0.1.0",
  "description": "Cravix Rider backend — distributed Express + Socket.IO + BullMQ.",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.12.0",
  "workspaces": [
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "build": "pnpm -r --parallel build",
    "dev": "pnpm --filter @cravix/api-gateway dev",
    "dev:socket": "pnpm --filter @cravix/socket-gateway dev",
    "dev:workers": "pnpm --filter @cravix/workers dev",
    "lint": "pnpm -r --parallel lint",
    "test": "pnpm -r --parallel test",
    "typecheck": "pnpm -r --parallel typecheck",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "db:seed": "tsx prisma/seed.ts",
    "docker:up": "docker compose -f docker-compose.yml up -d",
    "docker:down": "docker compose -f docker-compose.yml down",
    "docker:logs": "docker compose -f docker-compose.yml logs -f"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "prisma": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^6.0.1"
  }
}
