# =================================================================
# CRAVIX RIDER BACKEND — ENVIRONMENT VARIABLES
# =================================================================
# All 8 instances must read identical values for JWT and Redis keys.
# Distribute via secrets manager (AWS Secrets Manager / Vault).
# =================================================================

# -----------------------------------------------------------------
# APPLICATION
# -----------------------------------------------------------------
NODE_ENV=development
PORT=3000
SOCKET_PORT=5000
HOST=0.0.0.0
INSTANCE_ID=1                          # 1–8, set per container
LOG_LEVEL=info                         # debug | info | warn | error

# -----------------------------------------------------------------
# DATABASE — via PgBouncer
# -----------------------------------------------------------------
# Note: connection_limit=5 per instance; 8 inst x 5 = 40 -> pgbouncer pool 100
DATABASE_URL=postgresql://cravix_user:cravix_dev_pw@localhost:6432/cravix?connection_limit=5&pool_timeout=20

# -----------------------------------------------------------------
# REDIS CLUSTER
# -----------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=cravix:

# -----------------------------------------------------------------
# JWT — IDENTICAL ON ALL 8 INSTANCES
# Access = 3 minutes  | Refresh = 2 days  (locked decision A2)
# -----------------------------------------------------------------
JWT_ACCESS_SECRET=change-me-to-min-32-char-random-secret-please
JWT_REFRESH_SECRET=change-me-to-different-min-32-char-random-secret
JWT_ACCESS_EXPIRY=3m
JWT_REFRESH_EXPIRY=2d
JWT_ISSUER=cravix-rider-api
JWT_AUDIENCE=cravix-rider-app

# Optional rolling rotation key — if set, /auth/refresh accepts tokens
# signed by either the current or previous secret.
JWT_ACCESS_SECRET_PREVIOUS=

# -----------------------------------------------------------------
# RATE LIMITING (Redis store, shared across instances)
# -----------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
OTP_RATE_LIMIT_WINDOW_MS=600000        # 10 minutes
OTP_RATE_LIMIT_MAX=5                   # 5 OTP requests per phone / 10m
WITHDRAW_RATE_LIMIT_WINDOW_MS=86400000
WITHDRAW_RATE_LIMIT_MAX=3
REFRESH_RATE_LIMIT_WINDOW_MS=3600000
REFRESH_RATE_LIMIT_MAX=30

# -----------------------------------------------------------------
# CORS  (admin dashboard origins; mobile app uses no CORS)
# -----------------------------------------------------------------
ALLOWED_ORIGINS=https://admin.cravix.in,https://dashboard.cravix.in,http://localhost:5173

# -----------------------------------------------------------------
# REQUEST / SECURITY
# -----------------------------------------------------------------
MAX_BODY_SIZE=10kb
TRUSTED_PROXIES=1                      # Number of Nginx hops in front

# -----------------------------------------------------------------
# AUTH — OTP
# -----------------------------------------------------------------
OTP_LENGTH=4                           # Locked decision A1 (was 6)
OTP_TTL_SECONDS=300                    # 5 minutes
OTP_MAX_ATTEMPTS=5
OTP_LOCK_TTL_SECONDS=900               # 15 minutes
OTP_BCRYPT_ROUNDS=10

# -----------------------------------------------------------------
# AWS / S3
# -----------------------------------------------------------------
AWS_REGION=ap-south-1
AWS_S3_BUCKET=cravix-kyc
AWS_S3_CDN_BUCKET=cravix-cdn
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_PRESIGNED_URL_TTL=300
S3_MAX_UPLOAD_BYTES=5242880            # 5 MB cap on KYC uploads

# -----------------------------------------------------------------
# EXTERNAL SERVICES
# -----------------------------------------------------------------
GOOGLE_MAPS_API_KEY=

# SMS — MSG91
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=CRAVIX

# Push — FCM (base64-encoded service-account JSON)
FCM_SERVICE_ACCOUNT_JSON=

# Payment gateway — Razorpay
PAYMENT_GATEWAY=razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# -----------------------------------------------------------------
# OBSERVABILITY
# -----------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=
